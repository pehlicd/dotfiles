#!/bin/bash
# Restore the last-used wallpaper and theme on login.
# Called via exec-once in autostart.conf.

DOTFILES_DIR="$HOME/.local/share/dotfiles"
CURRENT_BG="$DOTFILES_DIR/current/background"
CURRENT_THEME="$DOTFILES_DIR/current/theme"

# ── Restore theme settings ──────────────────────────────────────────────

# Re-apply icon theme from saved setting
ICONS_FILE="$CURRENT_THEME/icons.theme"
if [ -f "$ICONS_FILE" ]; then
  gsettings set org.gnome.desktop.interface icon-theme "$(< "$ICONS_FILE")"
fi

# Re-apply cursor theme if set
CURSOR_FILE="$CURRENT_THEME/cursor.theme"
if [ -f "$CURSOR_FILE" ]; then
  gsettings set org.gnome.desktop.interface cursor-theme "$(< "$CURSOR_FILE")"
fi

# Re-apply GTK theme if set
GTK_FILE="$CURRENT_THEME/gtk.theme"
if [ -f "$GTK_FILE" ]; then
  gsettings set org.gnome.desktop.interface gtk-theme "$(< "$GTK_FILE")"
fi

# Kill xdg-desktop-portal-gtk so it picks up new theme
killall xdg-desktop-portal-gtk 2>/dev/null

# Regenerate Chrome/Chromium theme
generate-chrome-theme 2>/dev/null &

# ── Restore wallpaper ────────────────────────────────────────────────────

# Resolve the symlink to the actual wallpaper path
if [ -L "$CURRENT_BG" ] && [ -e "$CURRENT_BG" ]; then
  WALLPAPER=$(readlink -f "$CURRENT_BG")

  # Small delay to let Wayland compositor settle
  sleep 1

  # Apply via swaybg
  pkill -x swaybg
  setsid uwsm-app -- swaybg -i "$WALLPAPER" -m fill >/dev/null 2>&1 &
fi
