#!/bin/bash
source "$HOME/.local/share/dotfiles/bin/lib/helpers.sh"

show_menu() {
    clear
    echo -e "\e[1;36mв”Ңв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”җ\e[0m"
    echo -e "\e[1;36mв”Ӯ             THEME MANAGER                в”Ӯ\e[0m"
    echo -e "\e[1;36mв””в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”ҳ\e[0m"
    echo ""
    
    ACTION=$(gum choose \
        "Install Extra Theme" \
        "Remove Extra Theme" \
        "Update All Themes" \
        "Exit" \
        --header "Select an action:")

    case "$ACTION" in
        "Install Extra Theme")
            clear
            theme-install
            ;;
        "Remove Extra Theme")
            clear
            theme-remove
            ;;
        "Update All Themes")
            clear
            theme-update
            ;;
        "Exit")
            clear
            exit 0
            ;;
    esac

    echo ""
    gum confirm "Return to menu?" && show_menu || clear
}

show_menu
