#!/bin/bash
# Generate and apply Chrome/Chromium theme from the current system theme.
# Uses Chromium managed policies (like Omarchy) for live theme switching.
# Requires: sudo mkdir -p /etc/chromium/policies/managed && sudo chmod a+rw /etc/chromium/policies/managed

source "$HOME/.local/share/dotfiles/bin/lib/helpers.sh"

THEME_DIR="$HOME/.local/share/dotfiles/current/theme"
WAYBAR_CSS="$THEME_DIR/waybar.css"

# Extract background hex from active theme
get_theme_color() {
  if [[ -f "$WAYBAR_CSS" ]]; then
    grep '@define-color background' "$WAYBAR_CSS" | head -1 | grep -oP '#[0-9a-fA-F]{6}'
  fi
}

THEME_HEX=$(get_theme_color)

if [[ -z "$THEME_HEX" ]]; then
  # Fallback: dark neutral grey
  THEME_HEX="#1c2027"
fi

# Apply to Chromium
if command -v chromium &>/dev/null; then
  POLICY_DIR="/etc/chromium/policies/managed"
  if [[ -d "$POLICY_DIR" ]] && [[ -w "$POLICY_DIR" ]]; then
    echo "{\"BrowserThemeColor\": \"$THEME_HEX\"}" > "$POLICY_DIR/color.json"
    # Live-reload if Chromium is running
    if pgrep -x chromium &>/dev/null; then
      chromium --refresh-platform-policy --no-startup-window &>/dev/null &
    fi
    log_success "Chromium theme set: $THEME_HEX"
  else
    log_info "Chromium policy dir not set up. Run: sudo mkdir -p $POLICY_DIR && sudo chmod a+rw $POLICY_DIR"
  fi
fi

# Apply to Brave
if command -v brave &>/dev/null; then
  POLICY_DIR="/etc/brave/policies/managed"
  if [[ -d "$POLICY_DIR" ]] && [[ -w "$POLICY_DIR" ]]; then
    echo "{\"BrowserThemeColor\": \"$THEME_HEX\"}" > "$POLICY_DIR/color.json"
    if pgrep -x brave &>/dev/null; then
      brave --refresh-platform-policy --no-startup-window &>/dev/null &
    fi
    log_success "Brave theme set: $THEME_HEX"
  fi
fi

# Apply to Google Chrome
if command -v google-chrome-stable &>/dev/null; then
  POLICY_DIR="/etc/opt/chrome/policies/managed"
  if [[ -d "$POLICY_DIR" ]] && [[ -w "$POLICY_DIR" ]]; then
    echo "{\"BrowserThemeColor\": \"$THEME_HEX\"}" > "$POLICY_DIR/color.json"
    if pgrep -f google-chrome &>/dev/null; then
      google-chrome-stable --refresh-platform-policy --no-startup-window &>/dev/null &
    fi
    log_success "Chrome theme set: $THEME_HEX"
  fi
fi
